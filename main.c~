void RR(int *data, int n, int quantum){
	//Algoritmo de Round Robin

	int aux[n * COL];
	int cpu[n];
	int indices[n];
	int sumtot;
	int sumT = 0, orden;
	
	for (int i = 0; i < n; i++) {
		indices[i] = i;
		cpu[i] = data[i*COL + 1];
		sumtot += data[i * COL + 1];
		for (int j = 0; j < COL; j++)
			aux[i * COL + j] = data[i * COL + j];
	}

	for (int i = 0; i < n; i++)
	{
		int aux1, aux2;
		for (int j = i + 1; j < n; j++)
		{
			int aux1 = 0, aux2 = 0;
			if (aux[i * COL + 2] > aux[j * COL + 2])
			{
				aux1 = aux[i * COL + 2];
				aux[i * COL + 2] = aux[j * COL + 2];
				aux[j * COL + 2] = aux1;

				aux2 = indices[i];
				indices[i] = indices[j];
				indices[j] = aux2;
			}
		}
	}

	while (sumT < sumtot)
	{
		if (cpu[indices[0]] > quantum)
		{
			orden = indices[0];
			cpu[indices[0]] -= quantum;
			sumT += quantum;
			for (int j = 0; j < n - 2; j++)
				indices[j] = indices[j + 1];
			indices[n - 1] = orden;
		}
		else
		{
			sumT += cpu[indices[0]];
			data[indices[0] * COL + 3] = sumT;
			data[indices[0] * COL + 4] = data[indices[0] * COL + 3] - data[indices[0] * COL + 2];
			data[indices[0] * COL + 5] = data[indices[0] * COL + 4] - data[indices[0] * COL + 1];
		}
	}

